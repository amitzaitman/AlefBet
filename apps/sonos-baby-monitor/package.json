{
  "name": "sonos-baby-monitor",
  "version": "1.0.0",
  "type": "module",
  "description": "Use a Sonos speaker's mic as a baby monitor — detects sound and alerts via another Sonos speaker",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "ws": "^8.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.6.2",
    "vite": "^5.0.0"
  }
}
